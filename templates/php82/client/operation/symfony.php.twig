        $response = $this->httpClient->request(
            '{{ op.httpMethod|upper }}',
            $this->baseUrl . {{ op.phpPath }},
{% if hasQuery or op.requestBodyType is not null %}
            [
{% if hasQuery %}
                'query' => $query,
{% endif %}
{% if op.requestBodyType is not null %}
                'json' => $body->toRequestArray(),
{% endif %}
            ],
{% endif %}
        );
{% if op.returnType == 'void' %}
        // {{ op.successCodes|join(', ') }}
{% elseif op.returnsArray %}
        $result = array_map(
            static fn(array $item) => {{ op.returnType|split('\\')|last|replace({'[]': ''}) }}::fromResponseArray($item),
            $response->toArray(),
        );
{% if config.validationStrategy.name == 'NativeMethod' and config.validateClientResponse %}
        $this->validateNativeResponsePayload($result);
{% elseif config.validationStrategy.name == 'SymfonyConstraints' and config.validateClientResponse %}
        $this->validateSymfonyResponsePayload($result);
{% endif %}

        return $result;
{% else %}
        $result = {{ op.returnType|split('\\')|last }}::fromResponseArray($response->toArray());
{% if config.validationStrategy.name == 'NativeMethod' and config.validateClientResponse %}
        $this->validateNativeResponsePayload($result);
{% elseif config.validationStrategy.name == 'SymfonyConstraints' and config.validateClientResponse %}
        $this->validateSymfonyResponsePayload($result);
{% endif %}

        return $result;
{% endif %}
