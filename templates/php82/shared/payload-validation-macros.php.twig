{% macro renderNativePayloadMethod(indent) %}
{{ indent }}private function validateNativePayload(mixed $value): void
{{ indent }}{
{{ indent }}    if (is_array($value)) {
{{ indent }}        foreach ($value as $item) {
{{ indent }}            $this->validateNativePayload($item);
{{ indent }}        }
{{ indent }}
{{ indent }}        return;
{{ indent }}    }
{{ indent }}
{{ indent }}    if (is_object($value) && method_exists($value, 'validateOrThrow')) {
{{ indent }}        $value->validateOrThrow();
{{ indent }}    }
{{ indent }}}

