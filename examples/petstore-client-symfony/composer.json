{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "maxbeckers/php-openapi-generator": "*"
    },
    "config": {
        "allow-plugins": {
            "maxbeckers/php-openapi-generator": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Api\\": "generated/Api/",
            "App\\Model\\": "generated/Model/"
        }
    }
}
