{
  "name": "maxbeckers/php-openapi-generator",
  "description": "Parse OpenAPI specs with PHP",
  "type": "composer-plugin",
  "license": "MIT",
  "minimum-stability": "stable",
  "authors": [
    {
      "name": "Max Beckers",
      "email": "beckers.maximilian@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "composer-plugin-api": "^2.0",
    "maxbeckers/php-yaml-parser": "^0.3.0",
    "twig/twig": "^3.0",
    "symfony/console": "^6.0|^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "friendsofphp/php-cs-fixer": "^3.89",
    "phpstan/phpstan": "^1.12",
    "composer/composer": "^2.8"
  },
  "suggest": {
    "symfony/validator": "Required when validationStrategy is SymfonyConstraints"
  },
  "autoload": {
    "psr-4": {
      "MaxBeckers\\OpenApiGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MaxBeckers\\OpenApiGenerator\\Tests\\": "tests/"
    }
  },
  "bin": ["bin/openapi-gen"],
  "extra": {
    "class": "MaxBeckers\\OpenApiGenerator\\Plugin\\ComposerPlugin"
  },
  "scripts": {
    "test": "phpunit",
    "test-fast": "php -d xdebug.mode=off vendor/bin/phpunit",
    "cs": "php-cs-fixer fix --config=.php_cs.php -v --allow-risky=yes"
  }
}
